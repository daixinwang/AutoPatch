# =============================================
# 环境变量配置示例
# 复制本文件为 .env 并填入真实值
# =============================================

# Chat 模型 API Key (必填)
# 当前代码使用 langchain-anthropic 的 ChatAnthropic。
# 变量名保留 OPENAI_API_KEY / OPENAI_BASE_URL 是为了兼容 Anthropic-compatible 代理。
OPENAI_API_KEY=sk-ant-your-chat-api-key-here

# GitHub Personal Access Token (推荐设置，否则匿名访问限速 60 req/h)
# 创建方式: https://github.com/settings/tokens → Generate new token (classic)
# 所需权限: repo (读取私有仓库) 或仅 public_repo (只访问公开仓库)
GITHUB_TOKEN=ghp_your-github-token-here

# 可选：分别指定各 Agent 使用的模型
# PLANNER_MODEL_NAME=claude-haiku-4-5-20251001
# CODER_MODEL_NAME=claude-sonnet-4-6
# TEST_RUNNER_MODEL_NAME=claude-haiku-4-5-20251001
# REVIEWER_MODEL_NAME=claude-sonnet-4-6

# 可选：自定义 Chat API Base URL (使用 Anthropic-compatible 代理时填写)
# OPENAI_BASE_URL=https://your-proxy/v1

# 可选：Embedding 专用配置（未设置 OPENAI_EMBED_API_KEY 时回退到 OPENAI_API_KEY）
# OPENAI_EMBED_API_KEY=sk-your-openai-embedding-key-here
# OPENAI_EMBED_BASE_URL=https://api.openai.com/v1
# RAG_EMBEDDING_MODEL=text-embedding-3-small

# 可选：LangSmith 追踪 (推荐在调试阶段开启)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key
# LANGCHAIN_PROJECT=autopatch-agent

# PostgreSQL 连接串（断点续传所需，格式: postgresql://user:pass@host:port/dbname）
DATABASE_URL=postgresql://postgres:password@localhost:5432/autopatch
