# =============================================
# AutoPatch — .gitignore
# =============================================

# ── 环境变量（包含 API Key，绝对不能提交）──
.env
.env.local
.env.*.local

# ── Python ────────────────────────────────
# 虚拟环境
.venv/
venv/
env/
ENV/

# 编译缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# 测试与类型检查缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 分发包
dist/
build/
*.egg-info/
*.egg

# ── 前端 (Node.js / React) ─────────────────
# 依赖（体积大，通过 package.json 重新安装）
frontend/node_modules/

# Vite 构建产物
frontend/dist/
frontend/.vite/

# TypeScript 缓存
*.tsbuildinfo

# ── AutoPatch 产物 ─────────────────────────
# 评测结果（包含运行产物和 patch，不提交）
eval/results/

# 生成的补丁文件目录（取消注释可忽略）
# patches/

# 任务元数据目录（包含本地路径，不应提交）
tasks/

# 临时 clone 目录（以 autopatch_ 开头）
/tmp/autopatch_*/

# ── 操作系统 ───────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ── IDE / 编辑器 ───────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
